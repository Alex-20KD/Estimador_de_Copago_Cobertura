generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("https://xfxtmwobupurwbugkvvx.supabase.co")
}

model User {
  id            Int    @id @default(autoincrement())
  name          String
  insurancePlan String
}

model Hospital {
  id        Int    @id @default(autoincrement())
  name      String @unique
  specialty String
  baseCost  Float
}

model InsurancePlan {
  id                 Int    @id @default(autoincrement())
  name               String @unique
  coveragePercentage Float
}
