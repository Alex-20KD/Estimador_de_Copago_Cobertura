{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "buildCommand": "npm run build", 
  "installCommand": "npm install",
  "functions": { 
    "backend/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
} 